{
  "name": "ancestry-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Genealogy-based ancestry analysis with first-class uncertainty and historical place resolution.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "analyze:file": "tsx scripts/analyze-file.ts",
    "smoke": "tsx scripts/smoke.ts",
